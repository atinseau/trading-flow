# === Database ===
POSTGRES_USER=trading_flow
POSTGRES_PASSWORD=changeme-strong-secret
DATABASE_URL=postgres://trading_flow:changeme-strong-secret@localhost:5432/trading_flow
DATABASE_POOL_SIZE=10
DATABASE_SSL=false

# === Temporal ===
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE_SCHEDULER=scheduler
TEMPORAL_TASK_QUEUE_ANALYSIS=analysis
TEMPORAL_TASK_QUEUE_NOTIFICATIONS=notifications

# === Telegram (required) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === LLM providers (optional — only needed if a provider in watches.yaml uses them) ===
OPENROUTER_API_KEY=

# === Filesystem (operational) ===
ARTIFACTS_BASE_DIR=/data/artifacts
CLAUDE_WORKSPACE_DIR=/data/claude-workspace

# ----------------------------------------------------------------------------
# Live test gates (opt-in, cost real money / requires real services)
# ----------------------------------------------------------------------------
# RUN_LLM_OPENROUTER=1 enables test/llm/promptSmoke.test.ts (uses OPENROUTER_API_KEY)
# RUN_LLM_CLAUDE=1     enables test/llm/claudeSmoke.test.ts  (uses ANTHROPIC_API_KEY)
# RUN_LIVE_TELEGRAM=1  enables test/adapters/notify/TelegramNotifier.test.ts (live)
#                      requires TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID
# RUN_E2E=1            enables test/e2e/full-pipeline.test.ts
#                      requires `docker compose up -d` already running
# E2E_WATCH_ID=btc-1h  override default watch id used by force-tick E2E test
RUN_LLM_OPENROUTER=
RUN_LLM_CLAUDE=
RUN_LIVE_TELEGRAM=
RUN_E2E=
E2E_WATCH_ID=

# ANTHROPIC_API_KEY is only used by test/llm/claudeSmoke.test.ts; it is NOT used at runtime.
ANTHROPIC_API_KEY=
