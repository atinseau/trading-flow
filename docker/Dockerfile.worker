# syntax=docker/dockerfile:1.7

FROM oven/bun:1.3-debian AS deps

WORKDIR /app

# Playwright system deps for Chromium (runtime libs — must stay in final image).
# --no-install-recommends keeps the layer lean; cache mounts keep apt indices
# out of the image entirely.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
    libxfixes3 libxrandr2 libgbm1 libxshmfence1 libpango-1.0-0 \
    libcairo2 libasound2

COPY package.json bun.lock ./
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile

# Bake Playwright + Chromium into the image (no cache mount, so the binaries
# persist in the final layer instead of being re-downloaded at runtime).
# /ms-playwright is a fixed shared location so the same binaries are reachable
# from any runtime user.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
RUN bun x playwright install chromium && \
    chmod -R a+rX /ms-playwright

FROM deps AS runtime

COPY src ./src
COPY drizzle.config.ts biome.json tsconfig.json bunfig.toml ./
COPY prompts ./prompts
COPY migrations ./migrations

# Pre-create runtime data dirs with bun ownership so named volumes inherit it
# on first mount (Docker copies dir ownership into a fresh named volume).
RUN mkdir -p /data/artifacts /data/claude-workspace && \
    chown -R bun:bun /app /data

# Drop privileges. The official oven/bun image ships a `bun` user (uid 1000).
USER bun

ENV NODE_ENV=production
