    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "trustedDependencies": [
    "@temporalio/core-bridge",
    "@biomejs/biome",
    "playwright",
    "playwright-core"
  ],
