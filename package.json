{
  "name": "trading-flow",
  "module": "src/workers/scheduler-worker.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "test": "bun test",
    "test:domain": "bun test test/domain",
    "test:adapters": "bun test test/adapters",
    "test:workflows": "bun test test/workflows",
    "test:e2e": "RUN_E2E=1 bun test test/e2e",
    "test:integration:standby": "RUN_INTEGRATION_STANDBY=1 bun test test/integration/standby-boot.test.ts",
    "test:llm": "RUN_LLM_OPENROUTER=1 RUN_LLM_CLAUDE=1 bun test test/llm",
    "test:llm:openrouter": "RUN_LLM_OPENROUTER=1 bun test test/llm/promptSmoke.test.ts",
    "test:llm:claude": "RUN_LLM_CLAUDE=1 bun test test/llm/claudeSmoke.test.ts",
    "test:telegram": "RUN_LIVE_TELEGRAM=1 bun test test/adapters/notify/TelegramNotifier.test.ts",
    "test:full": "RUN_LLM_OPENROUTER=1 RUN_LLM_CLAUDE=1 RUN_LIVE_TELEGRAM=1 RUN_E2E=1 bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/cli/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "worker:scheduler": "bun run src/workers/scheduler-worker.ts",
    "worker:analysis": "bun run src/workers/analysis-worker.ts",
    "worker:notification": "bun run src/workers/notification-worker.ts",
    "worker:web": "bun run src/client/server.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
