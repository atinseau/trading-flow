    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.42.0",
    "handlebars": "^4.7.9",
    "jsdom": "^29.1.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
